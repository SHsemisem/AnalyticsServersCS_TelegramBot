BOT_TOKEN=                   # токен вашего бота
CHAT_ID=                     # ваш личный chat_id (или -100... для канала)

FTP_HOST=ip
FTP_USER=login
FTP_PASS=pass
FTP_PATH=/27015/cstrike/addons/amxmodx/logs/mapstats/mapstats_YYYY-MM-DD.log

TIMEZONE=Europe/Kyiv                  # ваш часовой пояс (+02:00 — Киев)
REPORT_TIME=23:00                     # время ежедневного отчета (формат HH:MM)
FTP_TIMEOUT=30                        # таймаут FTP-операций в секундах
SERVERS_FILE=servers.json             # JSON со списком серверов (если нужно несколько)
SERVER_NAME=main                      # используется для одиночной конфигурации
FTP_PASSIVE=false                     # включайте true, если нужен пассивный FTP